@model Player
@{
    ViewData["Title"] = "Remove Player";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-danger shadow">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0">&#128465; Remove Player from Squad</h5>
            </div>
            <div class="card-body text-center py-4">
                <img src="@(Model.PhotoURL ?? "/images/newProfileImage.png")"
                     style="width:90px;height:90px;border-radius:50%;object-fit:cover;
                 border:3px solid #dc3545;" />
                <h4 class="fw-bold mt-3">#@Model.JerseyNumber @Model.PlayerName</h4>
                <p class="text-muted">@Model.Position &bull; Age @Model.Age</p>
                <div class="alert alert-warning mt-3">
                    <strong>Warning:</strong> This will permanently delete the player
                    and all their associated ratings (@Model.TotalRatingsCount ratings).
                    This cannot be undone.
                </div>
                <div class="d-flex justify-content-center gap-3 mt-4">
                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="PlayerId" />
                        <button type="submit" class="btn btn-danger px-5 fw-bold">
                            Yes, Remove Player
                        </button>
                    </form>
                    <a asp-action="Index" class="btn btn-outline-secondary px-5">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</div>

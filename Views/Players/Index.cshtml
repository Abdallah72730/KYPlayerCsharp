@model IEnumerable<Player>
@{ ViewData["Title"] = "Squad"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0">
            <span style="color:#1F5C99">&#9917;</span> The Squad
        </h2>
        <small class="text-muted">@Model.Count() players registered</small>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-success px-4 py-2 fw-bold">
            &#43; Add Player
        </a>
    }
</div>

<!-- Search & Filter Bar -->
<form method="get" class="card card-body shadow-sm mb-4 p-3">
    <div class="row g-2 align-items-center">
        <div class="col-md-5">
            <input type="text" name="searchQuery" class="form-control"
                   placeholder="&#128269; Search by name or #jersey..."
                   value="@ViewData["SearchQuery"]" />
        </div>
        <div class="col-md-3">
            <select name="positionFilter" class="form-select">
                <option value="">All Positions</option>
                @foreach (var pos in new[]{ "Goalkeeper","Defender","Midfielder","Forward" })
                {
                    <option value="@pos" @(ViewData["PositionFilter"]?.ToString()==pos?"selected":"")>
                        @pos
                    </option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="sortBy" class="form-select">
                <option value="">Sort by...</option>
                <option value="psr_desc">PSR: High to Low</option>
                <option value="psr_asc">PSR: Low to High</option>
                <option value="name">Name A-Z</option>
                <option value="jersey">Jersey Number</option>
            </select>
        </div>
        <div class="col-md-1">
            <button type="submit" class="btn btn-primary w-100">Go</button>
        </div>
        <div class="col-md-1">
            <a asp-action="Index" class="btn btn-outline-secondary w-100">Clear</a>
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <h4>No players found.</h4>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-success mt-3">Add the first player</a>
        }
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var player in Model)
        {
            <div class="col">
                @await Html.PartialAsync("_PlayerCard", player)
            </div>
        }
    </div>
}

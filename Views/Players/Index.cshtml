@model IEnumerable<Player>
@{
    ViewData["Title"] = "Home"; Layout = "_Layout";
}

<!-- Hero Section -->
<div style="background:linear-gradient(135deg,#1F5C99,#0d2f52);
             color:#fff; padding:70px 20px; text-align:center;
             border-radius:16px; margin-bottom:40px;">
    <h1 style="font-size:3rem;font-weight:900;">KYPlayer</h1>
    <p style="font-size:1.3rem;opacity:0.85;max-width:600px;margin:0 auto 24px;">
        Know Your Players. Rate their performance. Follow the squad.
    </p>
    @if (!User.Identity!.IsAuthenticated)
    {
        <div class="d-flex gap-3 justify-content-center">
            <a asp-area="Identity" asp-page="/Account/Register"
               class="btn btn-light btn-lg fw-bold px-5">Join Now</a>
            <a asp-area="Identity" asp-page="/Account/Login"
               class="btn btn-outline-light btn-lg px-5">Login</a>
        </div>
    }
</div>

<!-- Rated Players -->
@if (Model.Any())
{
    <h3 class="fw-bold mb-4 text-center">Players This Season</h3>
    <div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
        @foreach (var player in Model)
        {
            <div class="col">
                @await Html.PartialAsync("_PlayerCard", player)
            </div>
        }
    </div>
}

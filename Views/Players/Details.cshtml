@model KYPlayer.Models.Player

<div class="row">
    <div class="col-md-4">
        <img src="@Model.PhotoURL" class="img-fluid rounded"/>
    </div>
    <div class="col-md-8">
        <h2>#@Model.JerseyNumber @Model.PlayerName</h2>
        <p>Position: @Model.Position | Age: @Model.Age</p>
        <p>PSR: <strong>@Model.CurrentPSR.ToString("0.0")</strong>/5.0  (@Model.TotalRatingsCount ratings)</p>

        @if (Model.Skills != null)
        {
            <h4>Skills</h4>
            <div class="mb-1">Shooting
                <div class="progress">
                    <div class="progress-bar" style='@($"width:{Model.Skills.Shooting}%;")'>@Model.Skills.Shooting</div>
                </div>
            </div>
            <div class="mb-1">Passing
                <div class="progress">
                    <div class="progress-bar" style='@($"width:{Model.Skills.Passing}%;")'>@Model.Skills.Passing</div>
                </div>
            </div>
            <div class="mb-1">
                Dribbling
                <div class="progress">
                    <div class="progress-bar" style='@($"width:{Model.Skills.Dribbling}%;")'>@Model.Skills.Dribbling</div>
                </div>
            </div>
            <div class="mb-1">
                Vision
                <div class="progress">
                    <div class="progress-bar" style='@($"width:{Model.Skills.Vision}%;")'>@Model.Skills.Vision</div>
                </div>
            </div>
            <div class="mb-1">
                Defense
                <div class="progress">
                    <div class="progress-bar" style='@($"width:{Model.Skills.Defense}%;")'>@Model.Skills.Defense</div>
                </div>
            </div>
            <div class="mb-1">
                Finishing
                <div class="progress">
                    <div class="progress-bar" style='@($"width:{Model.Skills.Finishing}%;")'>@Model.Skills.Finishing</div>
                </div>
            </div>
                
        }


        @if (User.Identity.IsAuthenticated && User.IsInRole("Fan"))
        {
            <h4>Rate this Player</h4>
            <form asp-controller="Ratings" asp-action="Create" method="post">
                <input type="hidden" name="PlayerId" value="@Model.PlayerId"/>
                <select name="Value" class="form-select" w-auto d-inline>
                    @for (int i = 1; i <= 5; i++) {<option value="@i">@i Star@(i>1?"s":"")</option> }
                </select>
                <button class="btn btn-warning ms-2">Submit Rating</button>

            </form>
        }
    </div>
</div>

@model KYPlayer.Models.ViewModels.AdminDashboardViewModel;
@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2 class="fw-bold mb-4">Admin Dashboard</h2>

<!-- Stat Cards Row -->
<div class="row g-4 mb-4">
    @foreach (var stat in new[]{
        ("Total Players",  Model.TotalPlayers.ToString(),  "#1F5C99", "&#9917"),
        ("Registered Fans",Model.TotalFans.ToString(),     "#1E8449", "&#128100"),
        ("Total Ratings",  Model.TotalRatings.ToString(),  "#E67E22", "&#9733") })
    {
        <div class="col-md-4">
            <div class="card text-white shadow-sm" style="background:@stat.Item3;border-radius:14px;">
                <div class="card-body d-flex justify-content-between align-items-center p-4">
                    <div>
                        <div style="font-size:2.4rem;font-weight:900;">@stat.Item2</div>
                        <div style="opacity:0.85;">@stat.Item1</div>
                    </div>
                    <div style="font-size:2.5rem;opacity:0.4;">@Html.Raw(stat.Item4)</div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Quick Action Buttons -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <a asp-controller="Players" asp-action="Create"
           class="btn btn-success w-100 py-3 fw-bold">Add Player</a>
    </div>
    <div class="col-md-3">
        <a asp-controller="Admin" asp-action="Ratings"
           class="btn btn-outline-warning w-100 py-3 fw-bold">Moderate Ratings</a>
    </div>
    <div class="col-md-3">
        <a asp-controller="Admin" asp-action="Users"
           class="btn btn-outline-danger w-100 py-3 fw-bold">Manage Users</a>
    </div>
    <div class="col-md-3">
        <a asp-controller="Admin" asp-action="Reports"
           class="btn btn-outline-primary w-100 py-3 fw-bold">Reports</a>
    </div>
</div>

<!-- Recent Ratings Table -->
<div class="card shadow-sm">
    <div class="card-header fw-bold">Recent Fan Ratings</div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Fan</th><th>Player</th><th>Rating</th><th>Time</th></tr>
            </thead>
            <tbody>
                @foreach (var r in Model.RecentRatings)
                {
                    <tr>
                        <td>@r.Fan?.UserName</td>
                        <td>@r.Player?.PlayerName</td>
                        <td>@for(int i=0;i<r.Value;i++){
                        <span style='color:#f39c12'>&#9733;</span>
                    }
</td>
                    <td><small class='text-muted'>@r.Timestamp.ToString("MMM dd, HH:mm")</small></td>
                </tr>
                                }
            </tbody>
        </table>
    </div>
</div>


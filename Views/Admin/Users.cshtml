@using KYPlayer.Areas.Identity.Data;

@model IEnumerable<ApplicationUser>
@{
    ViewData["Title"] = "Manage Users";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">&#128100; Manage Fans</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">&#8592; Dashboard</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr><th>#</th><th>Username</th><th>Email</th><th>Registered</th><th>Action</th></tr>
            </thead>
            <tbody>
                @{
                    int i = 1;
                }
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="text-muted">@i</td>
                        <td><strong>@user.UserName</strong></td>
                        <td>@user.Email</td>
                        <td>@user.CollegeEmail</td>
                        <td>
                            <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post"
                                  onsubmit="return confirm('Permanently delete @user.UserName?');">
                                <button class="btn btn-danger btn-sm">Remove User</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

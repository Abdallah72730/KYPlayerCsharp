@model IEnumerable<Rating>
@{
    ViewData["Title"] = "Moderate Ratings";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">&#9998; Moderate Ratings</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">&#8592; Dashboard</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No ratings to moderate.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Fan</th>
                        <th>Player</th>
                        <th>Rating</th>
                        <th>Date</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int row = 1;
                    }
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td class="text-muted">@row</td>
                            <td>@r.Fan?.UserName</td>
                            <td>
                                <a asp-controller="Players" asp-action="Details" asp-route-id="@r.PlayerId">
                                    @r.Player?.PlayerName
                                </a>
                            </td>
                            <td>
                                @for (int i = 0; i < r.Value; i++)
                                {
                                    <span style="color:#f39c12">&#9733;</span>
                                }
                                <small class="text-muted ms-1">(@r.Value/5)</small>
                            </td>
                            <td><small>@r.Timestamp.ToString("yyyy-MM-dd HH:mm")</small></td>
                            <td>
                                <form asp-action="DeleteRating" asp-route-id="@r.RatingId" method="post"
                                      onsubmit="return confirm('Remove this rating? PSR will be recalculated.');">
                                    <button class="btn btn-danger btn-sm">Remove</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
